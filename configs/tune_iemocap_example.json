{
  "run_name": "iemocap_baseline_search",
  "output_dir": "tuning_runs",
  "fixed_args": {
    "Dataset": "IEMOCAP",
    "iemocap-pkl-path": "data/iemocap_multimodal_features_rppg_ses01_v3.pkl",
    "iemocap-session-prefixes": "Ses01",
    "iemocap-six-class": false,
    "iemocap-no-valid-split": false,
    "epochs": 60,
    "temp": 1,
    "split-seed": 42,
    "iemocap-happy-class": 0,
    "valid-ratio": 0.15,
    "test-ratio": 0.25,
    "iemocap-rppg-npz-path": "data/iemocap_rppg_features_ses01_v3.npz",
    "ulgm-normalize-alpha": true,
    "class-weight-mode": "paper",
    "gamma-2-warmup-epochs": 6,
    "gamma-2-start": 0.2
  },
  "hard_constraints": {
    "enabled": true,
    "alpha_keys": ["ulgm-alpha-t", "ulgm-alpha-a", "ulgm-alpha-v", "ulgm-alpha-r"],
    "require_alpha_sum": 1.0,
    "alpha_sum_tolerance": 1e-6,
    "enforce_alpha_non_negative": true,
    "use_rppg_key": "use-rppg",
    "alpha_r_key": "ulgm-alpha-r",
    "only_when_normalize_alpha": true,
    "normalize_alpha_key": "ulgm-normalize-alpha"
  },
  "param_space": {
    "lr": [0.00005, 0.00008, 0.0001, 0.00012],
    "batch-size": [8, 16],
    "dropout": [0.2, 0.25, 0.3],
    "hidden_dim": [256],
    "n_head": [4, 8],
    "grad-clip": [0.8, 1.0],
    "use-rppg": [true],
    "ulgm-alpha-t": [0.35, 0.45],
    "ulgm-alpha-a": [0.2, 0.25],
    "ulgm-alpha-v": [0.15, 0.2],
    "ulgm-alpha-r": [0.15, 0.2],
    "ulgm-lambda-max": [0.0015, 0.002, 0.0025],
    "ulgm-lambda-min": [0.0005],
    "ulgm-e-delay": [2, 3],
    "ulgm-e-ramp": [8, 10],
    "gamma-2": [0.8, 1.0, 1.2],
    "gamma-3": [0.6, 0.8, 1.0],
    "pseudo-tau-conf": [0.75, 0.8],
    "pseudo-omega-major": [0.25, 0.3],
    "pseudo-omega-happy": [0.65, 0.75],
    "happy-boost-max": [1.6, 1.8],
    "happy-boost-epochs": [8, 12],
    "alpha-gate": [0.005, 0.01]
  }
}
